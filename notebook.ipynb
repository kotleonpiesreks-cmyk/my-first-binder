import pandas as pd
import numpy as np

# Dane do Twojej tabeli
produkty = ["telefon", "komputer", "tablet", "sluchawki", "tv", "glosnik"]
sprzedaz = np.random.randint(10, 100, size=len(produkty))
ceny = [2500, 4500, 1200, 350, 900, 450]

# Tworzenie tabeli (DataFrame)
df = pd.DataFrame({
    "PRODUKTY": produkty, 
    "SPRZEDAZ": sprzedaz, 
    "CENY": ceny
})

# Obliczanie przychodu
df["PRZYCHOD"] = df["SPRZEDAZ"] * df["CENY"]

# Wywołanie tabeli, żeby ją zobaczyć
df
